# ===========================
# تنظیمات ربات تلگرام
# ===========================

# توکن ربات از @BotFather
BOT_TOKEN=

# آیدی کانال (با @ یا عددی مثل -1001234567890)
CHANNEL_ID=

# لینک دعوت به کانال (https://t.me/yourchannel)
CHANNEL_LINK=

# آیدی‌های عددی ادمین‌ها — جداشده با ویرگول (مثال: 123456789,987654321)
ADMIN_IDS=

# ===========================
# اطلاعات کارت بانکی
# ===========================

CARD_NUMBER=
CARD_OWNER=

# ===========================
# تنظیمات دیتابیس و پیکربندی
# ===========================

# مسیر فایل دیتابیس SQLite (پیش‌فرض: bot_data.db)
DATABASE_PATH=bot_data.db

# فاصله زمانی بررسی timeout به دقیقه (پیش‌فرض: 30)
TIMEOUT_CHECK_INTERVAL_MINUTES=30

# مدت زمان تأیید فروشنده به ساعت (پیش‌فرض: 72)
SELLER_CONFIRM_TIMEOUT_HOURS=72
